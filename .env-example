# Copy this file to `.env` and fill in real values. `.env` is git-ignored — NEVER commit it.
# All secrets are read ONLY through the gatekeeper (src/.../shared/gatekeeper.py),
# never hard-coded anywhere in the codebase, notebooks, logs, or screenshots.

# ── Hugging Face ────────────────────────────────────────────────────────────
# Personal access token for gated/large model downloads. Treat like a password.
# Create at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# ── Model selection (overridable; see config/models.toml) ────────────────────
MODEL_ID=garage-bAInd/Platypus2-70B-instruct
SWEEP_MODEL_ID=meta-llama/Meta-Llama-3-8B
PRECISION=fp16
MAX_NEW_TOKENS=32

# ── AirLLM cache (put on FAST native ext4, e.g. ~/airllm_cache — NOT /mnt/c) ──
LAYER_SHARDS_SAVING_PATH=~/airllm_cache

# ── Economic model inputs (cite source + date in the report) ─────────────────
ELECTRICITY_RATE_PER_KWH=0.15
API_PRICE_IN_PER_1K=0.00025
API_PRICE_OUT_PER_1K=0.00125
HARDWARE_CAPEX=1999.0
HARDWARE_LIFE_MONTHS=36
